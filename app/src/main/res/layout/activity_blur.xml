<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212"
    android:padding="16dp">

    <!-- Top Action Bar / Info -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Blur Elements"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/button_clear_all"
            style="?android:attr/buttonBarButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Clear All"
            android:textColor="#FF5252"
            android:textSize="12sp" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Add blur boxes over parts of the image (like text or faces) to conceal them."
        android:textColor="#88FFFFFF"
        android:textSize="12sp"
        android:layout_marginBottom="16dp" />

    <!-- Blur Canvas Container -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#1E1E1E"
        android:layout_marginBottom="16dp">

        <com.example.urlimagewidget.BlurCanvasView
            android:id="@+id/blur_canvas_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center" />

        <ProgressBar
            android:id="@+id/blur_loading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone" />
    </FrameLayout>

    <!-- Strength Control Panel (Only visible when a box is selected) -->
    <LinearLayout
        android:id="@+id/layout_blur_strength"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="16dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/text_blur_strength_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Blur Strength: 10"
            android:textColor="#B3FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <SeekBar
            android:id="@+id/seek_bar_blur_strength"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="25"
            android:progress="10"
            android:thumbTint="#FFFFFF"
            android:progressTint="#FFFFFF" />
    </LinearLayout>

    <!-- Toolbar Controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="16dp">

        <Button
            android:id="@+id/button_add_box"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+ Add Blur Box"
            android:textColor="#121212"
            android:backgroundTint="#FFFFFF"
            android:layout_marginEnd="12dp" />

        <Button
            android:id="@+id/button_delete_box"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Delete Selected"
            android:textColor="#FFFFFF"
            android:backgroundTint="#FF5252"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Save / Back actions -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:spacing="12dp">

        <Button
            android:id="@+id/button_blur_cancel"
            style="?android:attr/buttonBarButtonStyle"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Cancel"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/button_blur_save"
            android:layout_width="0dp"
            android:layout_weight="1.5"
            android:layout_height="wrap_content"
            android:text="Apply Blur"
            android:textColor="#121212"
            android:backgroundTint="#4CAF50" />
    </LinearLayout>

</LinearLayout>
